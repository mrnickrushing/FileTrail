{
  "expo": {
    "name": "FileTrail",
    "slug": "filetrail",
    "owner": "rushingtechnologies",
    "version": "1.4.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "web": {
      "favicon": "./assets/icon.png"
    },
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.papertraill.app",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FileTrail uses your camera to scan physical documents — for example, a receipt, ID card, or bill — so it can save a digital copy in your vault.",
        "NSPhotoLibraryUsageDescription": "FileTrail accesses your photo library so you can import existing photos of documents — for example, a receipt, ID card, or insurance form already saved in your Photos app — and add them to your vault without retaking a picture.",
        "NSFaceIDUsageDescription": "FileTrail uses Face ID to protect your vault.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F12"
      },
      "package": "com.papertraill.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "cameraPermission": "FileTrail uses your camera to scan physical documents — for example, a receipt, ID card, or bill — so it can save a digital copy in your vault.",
          "photosPermission": "FileTrail accesses your photo library so you can import existing photos of documents — for example, a receipt, ID card, or insurance form already saved in your Photos app — and add them to your vault without retaking a picture.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#0F0F12"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      "expo-sharing"
    ],
    "scheme": "filetrail",
    "updates": {
      "url": "https://u.expo.dev/477b16b9-f591-4e43-8efe-6ef526a07ce0",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "477b16b9-f591-4e43-8efe-6ef526a07ce0"
      }
    }
  }
}
